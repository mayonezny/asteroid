# ─── Общий .env для docker compose ────────────────────────────────────────────
# Скопируйте в .env и подставьте реальные секреты перед prod-запуском:
#   cp .env.example .env
#
# Для dev-запуска (docker-compose.yml) можно оставить дефолты — переменные
# подставятся с fallback'ами.

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=diploma
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me-minio-password

# ─── JWT-секреты (обязательно перегенерируйте) ────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
# secure-куки в prod — true (нужен HTTPS перед frontend'ом)
JWT_COOKIE_SECURE=true
# Опционально: домен для куки refreshToken (пример: ".example.com")
# JWT_COOKIE_DOMAIN=

# ─── Прочее ───────────────────────────────────────────────────────────────────
DEFAULT_AVATAR_BASE_URL=https://cdn.example.com/avatars
MANAGER_PUBLIC_URL=http://manager:3000

# Порт, на котором nginx-фронт слушает на хосте (prod, только 127.0.0.1).
# Внешний nginx (vizhu) проксирует сюда после SSL-терминации.
FRONTEND_HTTP_PORT=8080
